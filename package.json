{
  "name": "docusaurus-plugin-gemini-search",
  "version": "0.2.0",
  "description": "Add a Gemini-powered AI assistant to your Docusaurus documentation.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "keywords": [
    "docusaurus",
    "docusaurus-plugin",
    "gemini",
    "gemini-file-search",
    "docs",
    "ai",
    "rag"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:zxcv1884/docusaurus-plugin-gemini-search.git"
  },
  "bugs": {
    "url": "https://github.com/zxcv1884/docusaurus-plugin-gemini-search/issues"
  },
  "homepage": "https://github.com/zxcv1884/docusaurus-plugin-gemini-search#readme",
  "bin": {
    "gemini-search": "./bin/gemini-search.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./sync": {
      "types": "./dist/sync.d.ts",
      "import": "./dist/sync.js",
      "default": "./dist/sync.js"
    }
  },
  "files": [
    "bin",
    "dist",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@google/genai": "^2.8.0"
  },
  "peerDependencies": {
    "@docusaurus/core": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@docusaurus/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@docusaurus/types": "^3.9.2",
    "@types/node": "^24.0.0",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
